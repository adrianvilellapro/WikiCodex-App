PORT=4000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=WikiCodex
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgresql_password_here
DATABASE_URL=postgresql://postgres:your_postgresql_password_here@localhost:5432/WikiCodex
PRISMA_LOG_QUERIES=false

# Auth
JWT_SECRET=change-this-in-development
JWT_EXPIRES_IN=7d
JWT_ISSUER=wikicodex-backend
JWT_AUDIENCE=wikicodex-app

# Bootstrap opcional:
# Solo se usa para generar el hash inicial de la clave de registro
# si la tabla configuracion_registro aun no existe.
ACCOUNT_REGISTRATION_CODE=change-this-code
ADMIN_ZONE_PASSWORD=change-this-admin-zone-password
ADMIN_DESTRUCTIVE_PASSWORD=change-this-destructive-password

# Uploads / media
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_media_api_key
CLOUDINARY_API_SECRET=your_media_api_secret
CLOUDINARY_FOLDER_ROOT=wikicodex
CLOUDINARY_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp,avif
CLOUDINARY_IMAGE_MAX_BYTES=768000
