model clases {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creado_por_usuario_id String?            @db.Uuid
  nombre                String
  nombre_normalizado    String?
  slug                  String?
  idioma_codigo         String             @default("en")
  fuente                String?
  edicion               String?
  es_catalogo           Boolean            @default(false)
  categoria_catalogo    String?
  descripcion           String?            @db.Text
  resumen               String?            @db.Text
  icono                 String?
  dado_golpe_caras      Int?
  salvaciones           Json               @default("[]")
  competencias          Json               @default("{}")
  equipo_inicial        Json               @default("[]")
  tabla                 Json               @default("[]")
  rasgos                Json               @default("[]")
  datos_fuente          Json               @default("{}")
  creado_en             DateTime           @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime           @default(now()) @db.Timestamptz(6)
  clase_campanas        clase_campanas[]
  personaje_clases      personaje_clases[]
  subclases             subclases[]
  usuarios              usuarios?          @relation(fields: [creado_por_usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_clases_creado_por")

  @@unique([slug, idioma_codigo, fuente], map: "uq_clases_slug_idioma_fuente")
  @@index([creado_por_usuario_id, creado_en, id], map: "idx_clases_creador_creado_en_id")
  @@index([categoria_catalogo, idioma_codigo, nombre, id], map: "idx_clases_categoria_idioma_nombre_id")
  @@index([es_catalogo, idioma_codigo, nombre, id], map: "idx_clases_catalogo_idioma_nombre_id")
  @@index([idioma_codigo, nombre, id], map: "idx_clases_idioma_nombre_id")
  @@index([nombre_normalizado], map: "idx_clases_nombre_normalizado")
}

model clase_campanas {
