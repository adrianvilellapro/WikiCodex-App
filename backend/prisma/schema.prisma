generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model ambitos_visibilidad_personaje {
  codigo      String       @id
  nombre      String       @unique
  descripcion String?
  personajes  personajes[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model arcos {
  id                    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campana_id            String     @db.Uuid
  aventura_id           String?    @db.Uuid
  nombre                String
  descripcion           String?
  imagen_url            String?
  fecha_inicio          DateTime?  @db.Date
  fecha_fin             DateTime?  @db.Date
  creado_por_usuario_id String     @db.Uuid
  creado_en             DateTime   @default(now()) @db.Timestamptz(6)
  actualizado_en        DateTime   @default(now()) @db.Timestamptz(6)
  aventuras             aventuras? @relation(fields: [aventura_id, campana_id], references: [id, campana_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_arcos_aventura")
  campanas              campanas   @relation(fields: [campana_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_arcos_campana")
  usuarios              usuarios   @relation(fields: [creado_por_usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_arcos_creado_por")
  partidas              partidas[]

  @@unique([id, campana_id], map: "uq_arcos_id_campana")
  @@index([aventura_id], map: "idx_arcos_aventura_id")
  @@index([campana_id], map: "idx_arcos_campana_id")
}

model asignaciones_categoria_objeto {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objeto_id         String            @db.Uuid
  categoria_id      String            @db.Uuid
  creado_en         DateTime          @default(now()) @db.Timestamptz(6)
  categorias_objeto categorias_objeto @relation(fields: [categoria_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_asignaciones_categoria_objeto_categoria")
  objetos           objetos           @relation(fields: [objeto_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_asignaciones_categoria_objeto_objeto")

  @@unique([objeto_id, categoria_id], map: "uq_asignaciones_categoria_objeto")
}

model asignaciones_categoria_personaje {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personaje_id         String               @db.Uuid
  categoria_id         String               @db.Uuid
  creado_en            DateTime             @default(now()) @db.Timestamptz(6)
  categorias_personaje categorias_personaje @relation(fields: [categoria_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_asignaciones_categoria_personaje_categoria")
  personajes           personajes           @relation(fields: [personaje_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_asignaciones_categoria_personaje_personaje")

  @@unique([personaje_id, categoria_id], map: "uq_asignaciones_categoria_personaje")
}

model asignaciones_categoria_poder {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
